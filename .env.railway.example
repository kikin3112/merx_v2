# =============================================================================
# FREE TIER DEPLOYMENT - RAILWAY + VERCEL
# =============================================================================
# Variables para Railway (Backend) y Vercel (Frontend)
# NO SUBIR este archivo con valores reales a git

# =============================================================================
# RAILWAY - BACKEND VARIABLES
# =============================================================================

# Entorno
ENVIRONMENT=production
DEBUG=False

# Base de datos (Railway provisiona automáticamente al agregar PostgreSQL)
# Dejar vacío para que Railway use la variable auto-generada
# DATABASE_URL se genera automáticamente al agregar PostgreSQL service

# Seguridad JWT - GENERAR NUEVO:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_GENERATE_NEW_SECRET_KEY_MINIMUM_32_CHARS

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS - URLs del frontend en Vercel
# Actualizar con tu URL de Vercel: https://tu-app.vercel.app
CORS_ORIGINS=https://TU-APP.vercel.app

# Sentry (opcional pero recomendado)
SENTRY_DSN=

# Redis (opcional - Railway puede provisionar)
# REDIS_URL=redis://default:password@host:6379

# =============================================================================
# VERCEL - FRONTEND VARIABLES
# =============================================================================

# URL del backend en Railway
VITE_API_URL=https://TU-BACKEND.railway.app/api/v1

# Entorno
VITE_ENVIRONMENT=production

# Sentry (opcional)
VITE_SENTRY_DSN=

# =============================================================================
# INSTRUCCIONES DE DESPLIEGUE
# =============================================================================
#
# PASO 1: Crear proyectos en Railway y Vercel
#   - Ir a railway.app y crear cuenta
#   - Ir a vercel.com y crear cuenta
#
# PASO 2: Conectar repositorio GitHub
#   - En Railway: New Project > Deploy from GitHub repo
#   - En Vercel: Add New... > Project > Import Git Repository
#
# PASO 3: Provisionar PostgreSQL en Railway
#   - En Railway Dashboard: Add Service > Database > PostgreSQL
#   - Railway generará automáticamente DATABASE_URL
#
# PASO 4: Configurar variables en Railway
#   - Ir a proyecto > Settings > Variables
#   - Agregar todas las variables de RAILWAY - BACKEND VARIABLES arriba
#   - SECRET_KEY: Generar con el comando indicado
#   - CORS_ORIGINS: URL de tu frontend en Vercel
#
# PASO 5: Configurar variables en Vercel
#   - Ir a proyecto > Settings > Environment Variables
#   - Agregar:
#     - VITE_API_URL: URL de tu backend en Railway + /api/v1
#     - VITE_ENVIRONMENT: production
#
# PASO 6: Deploy
#   - Railway: Se deploya automáticamente al conectar repo
#   - Vercel: Se deploya automáticamente al conectar repo
#
# PASO 7: Verificar
#   - Backend health: https://TU-BACKEND.railway.app/health
#   - Frontend: https://TU-APP.vercel.app
#
# PASO 8: Crear usuario admin
#   - Ejecutar seed: Railway Dashboard > proyecto > CLI
#   - Comando: curl -X POST https://TU-BACKEND.railway.app/api/v1/admin/seed
#
# =============================================================================
