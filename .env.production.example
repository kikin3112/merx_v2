# =============================================================================
# CHANDELIER ERP/POS - PRODUCTION ENVIRONMENT
# =============================================================================
# IMPORTANT: Copy this file to .env.production and fill in real values
# NEVER commit .env.production to version control!

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# DATABASE
# =============================================================================
# Use managed PostgreSQL in production (AWS RDS, DigitalOcean, etc.)
DB_NAME=chandelier_prod
DB_USER=chandelier_app
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_HOST=your-db-host.region.provider.com
DB_PORT=5432

# Connection pooling (adjust based on your workload)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30

# Transaction timeouts (milliseconds)
DB_STATEMENT_TIMEOUT=30000
DB_IDLE_IN_TRANSACTION_TIMEOUT=60000

# =============================================================================
# SECURITY - JWT
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_run_python_command_above_to_generate
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# CORS
# =============================================================================
# Your production domains (no http://localhost!)
CORS_ORIGINS=https://app.chandelier.com,https://www.chandelier.com

# =============================================================================
# SENTRY (Error Tracking)
# =============================================================================
# Get DSN from https://sentry.io
SENTRY_DSN=https://your-key@o0.ingest.sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# STORAGE (S3 / Cloudflare R2)
# =============================================================================
S3_ENABLED=True
S3_BUCKET=chandelier-prod-documents
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# For Cloudflare R2, use:
# S3_ENDPOINT_URL=https://account-id.r2.cloudflarestorage.com

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://redis:6379/0

# =============================================================================
# DOCKER COMPOSE PORTS
# =============================================================================
BACKEND_PORT=8000
FRONTEND_PORT=80
DB_PORT=5432
REDIS_PORT=6379

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME=Chandelier ERP/POS
APP_VERSION=1.0.0
