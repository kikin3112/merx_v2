# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*.so

# Environments
.venv
env/
venv/
ENV/
build/
develop-eggs/
dist/
wheels/

# Distribution / packaging
.Python
*.egg-info/
.installed.cfg
*.egg

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*,cover
.mypy_cache/
.pyre/
.pytype/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Application logs
logs/
*.log

# Editors and IDEs
# PyCharm
.idea/  # Uncomment this to ignore the entire .idea folder
# VS Code
.vscode/
# Spyder
.spyderproject
.spyproject

# OS-specific files
.DS_Store # macOS
Thumbs.db # Windows

# Environment variables — NEVER commit these
.env
.env.local
.env.*.local
.env.production
.env.railway
.env.development
backend/.env
frontend/.env.local

# Python version management
.python-version

# UV lock file (si usas uv para dependencias)
uv.lock

# Cursor IDE
.cursor/.env
.vercel

# Windows crash dumps
*.stackdump

# Marketing binary assets (images, fonts, videos — too large for git)
.claude/ecosystem/nodes/marketing/assets/

# CARL session runtime files (auto-generated, not for version control)
.carl/sessions/*.json
.worktrees/
