# =============================================================================
# CHANDELIERP - PRODUCTION ENVIRONMENT CONFIGURATION
# =============================================================================
#
# IMPORTANTE: Copiar este archivo como .env.production y completar con valores reales
# NO SUBIR .env.production A GIT (está en .gitignore)
#

# =============================================================================
# ENTORNO
# =============================================================================
ENVIRONMENT=production
DEBUG=False

# =============================================================================
# BASE DE DATOS (PostgreSQL)
# =============================================================================
# OPCIÓN 1: Managed Database (DigitalOcean, Railway, Heroku)
DB_URL=postgresql://user:password@managed-db-host.example.com:5432/chandelier_prod

# OPCIÓN 2: Self-hosted en VPS (mismo servidor que la app)
# DB_URL=postgresql://postgres:STRONG_PASSWORD_HERE@localhost:5432/chandelier_prod

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30
DB_STATEMENT_TIMEOUT=30000
DB_IDLE_IN_TRANSACTION_TIMEOUT=60000

# =============================================================================
# SEGURIDAD JWT
# =============================================================================
# GENERAR: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_PYTHON_SECRETS_MINIMUM_32_CHARS

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# APLICACIÓN
# =============================================================================
APP_NAME=MERX v2
APP_VERSION=1.0.0
API_PREFIX=/api/v1

# =============================================================================
# CORS (Frontend URLs)
# =============================================================================
# Agregar SOLO los dominios de producción (sin http://localhost)
CORS_ORIGINS=https://app.chandelier.com,https://www.chandelier.com
CORS_ALLOW_CREDENTIALS=True
CORS_MAX_AGE=600

# =============================================================================
# ERROR TRACKING (SENTRY)
# =============================================================================
# Crear proyecto en sentry.io y obtener DSN
SENTRY_DSN=https://your-key@o0.ingest.sentry.io/project-id

# =============================================================================
# STORAGE (S3/Cloudflare R2)
# =============================================================================
S3_ENABLED=True
S3_BUCKET=chandelier-prod-docs
S3_REGION=auto
S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=your-cloudflare-r2-access-key
AWS_SECRET_ACCESS_KEY=your-cloudflare-r2-secret-key

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=True

# =============================================================================
# EMAIL (SMTP) - Para notificaciones
# =============================================================================
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@your-domain.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@chandelier.com

# =============================================================================
# WOMPI (Pagos Online) - OPCIONAL
# =============================================================================
WOMPI_PUBLIC_KEY=pub_prod_your_public_key
WOMPI_PRIVATE_KEY=prv_prod_your_private_key
WOMPI_WEBHOOK_SECRET=your_webhook_secret
WOMPI_ENABLED=True

# =============================================================================
# MONITORING
# =============================================================================
# UptimeRobot: Configurar monitor en https://uptimerobot.com
# Monitorear: https://app.chandelier.com/health
# Interval: 5 minutes
# Alert: Email + SMS si down >1 minuto
